---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero";
import UseCases from "../components/UseCases";
import FinalCTA from "../components/FinalCTA";

export const prerender = true;
---

<Layout
	title="Nicolas Moreno | Remote Backend & Full-Stack Developer | Django, NestJS, React | Colombia"
	description="Hire Nicolas Moreno — Remote Software Engineer from Colombia. 2+ years building scalable APIs with Django, NestJS, React & Docker. AWS certified. Available for contract & full-time remote roles in LATAM timezone."
>
	<div class="relative z-10 w-full overflow-hidden">
		<Hero client:load />

		{
			/* Hub Navigation: Users identify themselves here and click through to specific pages */
		}
		<div id="use-cases">
			<UseCases client:visible />
		</div>

		<div id="contact">
			<FinalCTA client:visible />
		</div>
	</div>
</Layout>
