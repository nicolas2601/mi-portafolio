---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero";
import FinalCTA from "../components/FinalCTA";
import FAQ from "../components/FAQ";

export const prerender = true;
---

<Layout
	title="Contacto | Nicolas Moreno"
	description="¿Listo para iniciar tu próximo proyecto? Agenda una consultoría gratuita o contáctame directamente para discutir cómo la automatización y el desarrollo backend pueden potenciar tu empresa."
>
	<main>
		<PageHero
			title="Hablemos de tu Proyecto"
			subtitle="Agenda una consultoría gratuita y definamos el siguiente paso."
			variant="contact"
			client:load
		/>

		<FinalCTA client:visible />

		<FAQ client:visible />
	</main>
</Layout>
