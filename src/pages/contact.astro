---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero";
import FinalCTA from "../components/FinalCTA";
import FAQ from "../components/FAQ";

export const prerender = true;
---

<Layout
	title="Hire Nicolas Moreno | Contact & Free Consultation | Remote Developer Colombia"
	description="Get in touch with Nicolas Moreno for backend development, automation, or full-stack projects. Free 30-minute consultation. Available for remote work from Colombia (Americas timezone)."
>
	<PageHero
		title="Hablemos de tu Proyecto"
		subtitle="Agenda una consultoría gratuita y definamos el siguiente paso."
		variant="contact"
		client:load
	/>

	<FinalCTA client:visible />

	<FAQ client:visible />
</Layout>
