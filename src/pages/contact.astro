---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero";
import FinalCTA from "../components/FinalCTA";
import FAQ from "../components/FAQ";

export const prerender = true;
---

<Layout
	title="Contacto & Consultoría | Nicolas Moreno"
	description="Agenda una consultoría gratuita para tu próximo proyecto. Hablemos de automatización, backend y cómo escalar tu infraestructura tecnológica."
>
	<PageHero
		title="Hablemos de tu Proyecto"
		subtitle="Agenda una consultoría gratuita y definamos el siguiente paso."
		variant="contact"
		client:load
	/>

	<FinalCTA client:visible />

	<FAQ client:visible />
</Layout>
