---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero";
import ProjectsComponent from "../components/Projects";
import FinalCTA from "../components/FinalCTA";

export const prerender = true;
---

<Layout
	title="Proyectos Reales | Nicolas Moreno"
	description="Explora mi portafolio de proyectos de desarrollo de software: Sistemas de reservas, plataformas IoT, E-commerce automatizados y aplicaciones móviles con IA. Código real, impacto real."
>
	<main>
		<PageHero
			title="Portafolio de Ingeniería"
			subtitle="Resultados medibles: Desde bots de WhatsApp hasta arquitecturas empresariales."
			variant="projects"
			client:load
		/>

		<ProjectsComponent client:visible />

		<FinalCTA client:visible />
	</main>
</Layout>
