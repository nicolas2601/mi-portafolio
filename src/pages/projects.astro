---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero";
import ProjectsComponent from "../components/Projects";
import FinalCTA from "../components/FinalCTA";

export const prerender = true;
---

<Layout
	title="Portfolio & Projects | Nicolas Moreno | Django, React, IoT, AI Applications"
	description="Real-world software engineering projects: automated booking systems, real-time IoT dashboards, e-commerce with full automation, and ML-powered mobile apps. Built with Django, React, NestJS & Docker."
>
	<PageHero
		title="Portafolio de Ingeniería"
		subtitle="Resultados medibles: Desde bots de WhatsApp hasta arquitecturas empresariales."
		variant="projects"
		client:load
	/>

	<ProjectsComponent client:visible />

	<FinalCTA client:visible />
</Layout>
