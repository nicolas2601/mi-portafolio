---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero";
import AboutComponent from "../components/About";
import FinalCTA from "../components/FinalCTA";

export const prerender = true;
---

<Layout
	title="About Nicolas Moreno | Remote Software Engineer | Django, React, AWS | Colombia"
	description="Nicolas Moreno — Systems Engineer & Full-Stack Developer from Bucaramanga, Colombia. 2+ years of experience with Django, NestJS, React, Docker. AWS certified. Download my CV and explore my career."
>
	<PageHero
		title="Ingeniero & Solucionador de Problemas"
		subtitle="Más allá del código: construyo sistemas que funcionan en el mundo real."
		variant="about"
		client:load
	/>

	<AboutComponent client:visible />

	<FinalCTA client:visible />
</Layout>
