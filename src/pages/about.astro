---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero";
import AboutComponent from "../components/About";
import FinalCTA from "../components/FinalCTA";

export const prerender = true;
---

<Layout
	title="Sobre Mí - Mi Trayectoria | Nicolas Moreno"
	description="Nicolas Moreno, Ingeniero de Sistemas en formación. Especialista en Django/React enfocado en construir soluciones tecnológicas que resuelven problemas reales."
>
	<PageHero
		title="Ingeniero & Solucionador de Problemas"
		subtitle="Más allá del código: construyo sistemas que funcionan en el mundo real."
		variant="about"
		client:load
	/>

	<AboutComponent client:visible />

	<FinalCTA client:visible />
</Layout>
