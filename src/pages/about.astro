---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero";
import AboutComponent from "../components/About";
import FinalCTA from "../components/FinalCTA";

export const prerender = true;
---

<Layout
	title="Sobre Mí | Nicolas Moreno"
	description="Conoce a Nicolas Moreno, Ingeniero de Sistemas en formación y apasionado por la tecnología. Mi trayectoria, habilidades técnicas en Django/React y filosofía de trabajo enfocada en resultados."
>
	<main>
		<PageHero
			title="Ingeniero & Solucionador de Problemas"
			subtitle="Más allá del código: construyo sistemas que funcionan en el mundo real."
			variant="about"
			client:load
		/>

		<AboutComponent client:visible />

		<FinalCTA client:visible />
	</main>
</Layout>
