---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero";
import ServicesSection from "../components/Services";
import FinalCTA from "../components/FinalCTA";

export const prerender = true;
---

<Layout
    title="Backend Development & Automation Services | Nicolas Moreno | Hire Remote Developer"
    description="Custom backend development, REST API design, process automation, WhatsApp bots & full-stack web applications. Hire a remote developer from Colombia for your next project."
>
    <PageHero
        title="Soluciones de Automatización & Backend"
        subtitle="Infraestructura escalable y bots inteligentes para potenciar tu negocio."
        variant="services"
        client:load
    />

    <ServicesSection client:visible />

    <FinalCTA client:visible />
</Layout>
