---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero";

export const prerender = true;
---

<Layout
    title="Política de Privacidad | Nicolas Moreno"
    description="Política de Privacidad de Nicolas Moreno. Conoce cómo protegemos tus datos, el uso de formularios de contacto y tu derecho a la privacidad en este portafolio."
>
    <PageHero
        title="Política de Privacidad"
        subtitle="Transparencia y seguridad en el manejo de tu información."
        variant="default"
        client:load
    />
    <section class="py-20 max-w-4xl mx-auto px-4 text-gray-300">
        <h2 class="text-2xl font-bold text-white mb-4">Protección de Datos</h2>
        <p class="mb-4">
            Valoramos tu privacidad. Este sitio web de portafolio no recopila
            datos personales sin tu consentimiento explícito a través del
            formulario de contacto.
        </p>
        <h2 class="text-2xl font-bold text-white mb-4">
            Información de Contacto
        </h2>
        <p>
            Cualquier dato proporcionado (correo electrónico, nombre) se utiliza
            únicamente con fines de comunicación profesional y no se comparte
            con terceros.
        </p>
    </section>
</Layout>
