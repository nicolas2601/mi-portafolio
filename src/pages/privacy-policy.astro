---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero";

export const prerender = true;
---

<Layout
    title="Privacy Policy | Nicolas Moreno"
    description="Privacy Policy for Nicolas Moreno's Portfolio"
>
    <main>
        <PageHero
            title="Privacy Policy"
            subtitle="Transparent and secure data handling."
            variant="default"
            client:load
        />
        <section className="py-20 max-w-4xl mx-auto px-4 text-gray-300">
            <h2 className="text-2xl font-bold text-white mb-4">
                Protection of Data
            </h2>
            <p className="mb-4">
                We value your privacy. This portfolio website does not collect
                personal data without your explicit consent via the contact
                form.
            </p>
            <h2 className="text-2xl font-bold text-white mb-4">
                Contact Information
            </h2>
            <p>
                Any data provided (email, name) is used solely for professional
                communication purposes.
            </p>
        </section>
    </main>
</Layout>
